package src;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;
import java.util.stream.Stream;

public class Javastream1 {
	public static void main(String[] args) {
		String[] names= {"Lakshu","Adam","Merlin","Angel","Karunya","Devaraj","Sam"};
		List<String> list=Arrays.asList(names);
		list.stream().filter(s->s.startsWith("M")).map(s->s.toUpperCase()).forEach(s->System.out.println(s));
		List<String> names1=Arrays.asList("Ranjith","Rockey","Praiseson");
		Stream<String> newStream=Stream.concat(list.stream(), names1.stream());
		//newStream.sorted().forEach(s->System.out.println(s));
		newStream.anyMatch(s->s.equalsIgnoreCase("Angel"));
		
	}

}
